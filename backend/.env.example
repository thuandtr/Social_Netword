# Server Configuration
NODE_ENV=development
PORT=5000

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=test#1
MYSQL_DATABASE=test

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=thisIsASecretKeyForJWTTokenGeneration

# Encryption Configuration
ENCRYPTION_KEY=MyUOtSUaX0XH2jJtRV/DDfD5Ly78/Xau22/p06MKPCU=
ENCRYPTION_IV=1234567890123456

# Cookie Configuration
COOKIE_SECRET=thisIsASecretKeyForCookie

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google OAuth2 Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary Configuration (image hosting)
# Get these from: https://console.cloudinary.com -> Settings -> API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=411195479129968
CLOUDINARY_API_SECRET=your-api-secret

# File Upload Configuration (optional)
# MAX_FILE_SIZE=5242880  # 5MB in bytes
# UPLOAD_PATH=./uploads
